      </concept>
      <concept>
        <code value="IMP"/>
        <display value="inpatient encounter"/>
      </concept>
      <concept>
        <code value="NONAC"/>
        <display value="inpatient non-acute"/>
      </concept>
      <concept>
        <code value="OBSENC"/>
        <display value="observation encounter"/>
      </concept>
      <concept>
        <code value="SS"/>
