          <valueString value="define function ObservationLabCoding(coding List&lt;Coding&gt;):   coding c   return Coding{     id: c.id,     extension: c.extension,     system: c.system,     version: c.version,     code: c.code,     display: c.display,     userSelected: c.userSelected   }"/>
