          <valueString value="SharedResourceCreation"/>
        </extension>
        <extension url="name">
          <valueString value="MetaElement"/>
        </extension>
        <extension url="statement">
          <valueString value="define function &quot;MetaElement&quot;(resource Resource, profileURLs List&lt;FHIR.canonical&gt;):   resource r   return FHIR.Meta{     extension: r.meta.extension,     versionId: r.meta.versionId,     lastUpdated: r.meta.lastUpdated,     profile: profileURLs,     security: r.meta.security,     tag: r.meta.tag   }"/>
