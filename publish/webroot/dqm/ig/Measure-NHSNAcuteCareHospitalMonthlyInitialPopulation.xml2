        </extension>
        <extension url="name">
          <valueString value="RemoveUnaccepted"/>
        </extension>
        <extension url="statement">
          <valueString value="define function RemoveUnaccepted(codes List&lt;FHIR.CodeableConcept&gt;, accepted List&lt;System.Code&gt;):  codes c   where exists(     accepted a     where c ~ a   )"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="76"/>
        </extension>
      </extension>
