      {
        "url" : "statement",
        "valueString" : "define \"Get Locations from IP Encounters in Measurement Period\":   flatten(\"Initial Population\" IP   let locationElements: IP.location   return     locationElements LE     let locationReference: LE.location     return NHSNHelpers.GetLocation(locationReference))"
      },
